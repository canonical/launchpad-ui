{
  "name": "launchpad-ui",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:mock": "vite dev --mode mock",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "lint:fix": "bun run format && eslint . --fix",
    "check": "bun run check:svelte && bun run lint",
    "check:fix": "bun run check:svelte && bun run lint:fix",
    "check:svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:svelte:watch": "bun run check:svelte -- --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:server": "bun run test --project=server",
    "test:client": "bun run test --project=client",
    "test:ssr": "bun run test --project=ssr",
    "test:client:chromium": "bun run test --project=client --browser=chromium",
    "test:client:firefox": "bun run test --project=client --browser=firefox",
    "test:client:webkit": "bun run test --project=client --browser=webkit",
    "test:watch:client": "bun run test:watch --project=client --browser.headless=false",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "openapi:update": "bun run openapi:update-schema && bun run openapi:generate-types",
    "openapi:update-schema": "./scripts/openapi-update-schema.sh",
    "openapi:generate-types": "openapi-typescript .api-spec/job-manager.yaml -o src/lib/api/job-manager/types.ts --root-types --root-types-no-schema-prefix --enum-values",
    "mock-server": "prism mock .api-spec/job-manager.yaml --port 4010",
    "mock-server:dynamic": "bun run mock-server -d"
  },
  "devDependencies": {
    "@canonical/svelte-ssr-test": "^0.25.0",
    "@chromatic-com/storybook": "^5.1.2",
    "@eslint/js": "^10.0.1",
    "@stoplight/prism-cli": "^5.14.2",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/addon-themes": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/sveltekit": "^10.3.5",
    "@sveltejs/adapter-node": "^5.5.0",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^25.0.8",
    "@vitest/browser-playwright": "^4.1.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-storybook": "^10.3.5",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "openapi-sampler": "^1.6.2",
    "openapi-typescript": "^7.10.1",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "storybook": "^10.3.5",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.7",
    "vitest": "^4.1.3",
    "vitest-browser-svelte": "^2.1.0"
  },
  "patchedDependencies": {
    "markdown-actions@1.1.2": "patches/markdown-actions@1.1.2.patch",
    "@stoplight/prism-http@5.12.0": "patches/@stoplight%2Fprism-http@5.12.0.patch"
  },
  "dependencies": {
    "@canonical/svelte-ds-app-launchpad": "^0.25.0",
    "@canonical/svelte-icons": "^0.0.9",
    "@floating-ui/dom": "^1.7.4",
    "markdown-actions": "^1.1.2",
    "openapi-fetch": "^0.15.0",
    "valibot": "^1.2.0"
  }
}
