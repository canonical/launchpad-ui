{
  "name": "launchpad-ui",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@10.6.2",
  "engines": {
    "node": ">=26.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite dev",
    "dev:mock": "vite dev --mode mock",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "lint:fix": "pnpm run format && eslint . --fix",
    "check": "pnpm run check:svelte && pnpm run lint",
    "check:fix": "pnpm run check:svelte && pnpm run lint:fix",
    "check:svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:svelte:watch": "pnpm run check:svelte -- --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:server": "pnpm run test --project=server",
    "test:client": "pnpm run test --project=client",
    "test:client:chromium": "pnpm run test --project=client --browser=chromium",
    "test:client:firefox": "pnpm run test --project=client --browser=firefox",
    "test:client:webkit": "pnpm run test --project=client --browser=webkit",
    "test:watch:client": "pnpm run test:watch --project=client --browser.headless=false",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@canonical/launchpad-design-tokens": "^1.1.1",
    "@canonical/svelte-ssr-test": "^0.25.0",
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/addon-themes": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/sveltekit": "^10.4.6",
    "@sveltejs/adapter-node": "^5.5.7",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^25.9.4",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-storybook": "^10.4.6",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "msw": "^2.14.6",
    "playwright": "^1.61.1",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^3.5.2",
    "storybook": "^10.4.6",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vitest-browser-svelte": "^2.1.1"
  },
  "dependencies": {
    "@canonical/svelte-ds-app-launchpad": "^0.27.0",
    "@canonical/svelte-icons": "^0.0.9",
    "@floating-ui/dom": "^1.7.6",
    "markdown-actions": "^1.1.2",
    "openapi-fetch": "^0.15.2",
    "undici": "^8.5.0",
    "valibot": "^1.4.1"
  },
  "msw": {
    "workerDirectory": [
      "static"
    ]
  }
}
